# ─── Model Configuration ─────────────────────────────────────────────────────
# HuggingFace model to use for zero-shot classification
MODEL_NAME=facebook/bart-large-mnli

# Score threshold (0.0 – 1.0) above which a label is considered "flagged"
THRESHOLD=0.3

# Maximum number of characters accepted per request
MAX_TEXT_LENGTH=1024

# ─── API Configuration ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── GPU Acceleration (optional) ─────────────────────────────────────────────
# Set to "0" to use the first NVIDIA GPU, or leave unset for CPU
# CUDA_VISIBLE_DEVICES=0
